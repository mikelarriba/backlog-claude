# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# ── Logging ───────────────────────────────────────────────────────────────────
# One of: debug | info | warn | error  (default: info)
LOG_LEVEL=info

# ── Inbox watcher ────────────────────────────────────────────────────────────
# Number of retry attempts before moving a failed inbox file to inbox/errors/ (default: 3)
INBOX_MAX_RETRIES=3

# ── Audit log ─────────────────────────────────────────────────────────────────
# Path to the append-only NDJSON audit log. Set to "none" to disable auditing.
# Default: ./audit.log
AUDIT_LOG_PATH=./audit.log

# ── JIRA connection ───────────────────────────────────────────────────────────
JIRA_BASE_URL=https://your-jira-instance.example.com/jira
JIRA_API_TOKEN=your-personal-access-token

# ── JIRA project scoping ─────────────────────────────────────────────────────
# The JIRA project key used for all issue operations (default: EAMDM)
JIRA_PROJECT=EAMDM
# The JIRA label applied to issues created from this backlog (default: MIDAS_Development)
JIRA_LABEL=MIDAS_Development

# ── JIRA custom field IDs ─────────────────────────────────────────────────────
# These IDs are instance-specific. Find yours at:
#   JIRA > Administration > Issues > Custom fields
# (defaults below are for the VW Group JIRA instance)
JIRA_FIELD_EPIC_NAME=customfield_10002
JIRA_FIELD_EPIC_LINK=customfield_10000
JIRA_FIELD_STORY_POINTS=customfield_10006

# ── JIRA Agile (Sprint sync) ──────────────────────────────────────────────────
# Board ID for sprint lookup. Find yours at:
#   JIRA > Boards > your board > the number in the URL (?rapidView=123)
# Required only if you want sprint assignments to sync during push.
JIRA_BOARD_ID=

# ── SSE connections ───────────────────────────────────────────────────────────
# Idle timeout in milliseconds before a silent SSE client is evicted (default: 300000 = 5 min)
SSE_IDLE_TIMEOUT_MS=300000

# ── AI generation ─────────────────────────────────────────────────────────────
# Max parallel AI (Claude / GitHub Models / Ollama) calls at any given time (default: 3)
# Requests beyond this limit are queued in FIFO order rather than failing.
CLAUDE_CONCURRENCY=3
# Timeout in milliseconds for non-streaming Claude CLI calls (default: 180000 = 3 min)
CLAUDE_TIMEOUT_MS=180000
# Timeout in milliseconds for streaming Claude CLI calls (default: 300000 = 5 min)
CLAUDE_STREAM_TIMEOUT_MS=300000

# ── Ollama local LLM provider ──────────────────────────────────────────────────
# Ollama lets you run LLMs locally at no cost.  The app auto-detects a running
# Ollama instance on startup; no manual config is needed for the default setup.
#
# How to use:
#   1. Install Ollama: https://ollama.com
#   2. Pull a model:   ollama pull llama3
#   3. Start Ollama:   ollama serve
#   4. Open the app → ⚙ AI Model → click ↺ to refresh the provider list
#      → select "Ollama (local)" and pick a model.
#
# Override OLLAMA_BASE_URL only when Ollama runs on a non-default port or host
# (e.g. inside Docker or on a remote machine).
# Default: http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434

# ── JIRA performance ──────────────────────────────────────────────────────────
# Max parallel JIRA API requests during bulk operations (default: 5)
JIRA_CONCURRENCY=5
# Request timeout in milliseconds for JIRA API calls (default: 30000)
JIRA_TIMEOUT_MS=30000

# ── JIRA circuit breaker ───────────────────────────────────────────────────────
# Number of consecutive failures before the circuit opens (default: 5)
JIRA_CIRCUIT_FAILURE_THRESHOLD=5
# Milliseconds before a half-open probe is attempted after the circuit opens (default: 30000)
JIRA_CIRCUIT_RESET_TIMEOUT_MS=30000


# ── Rate limiting ─────────────────────────────────────────────────────────────
# Requests per minute per IP for general API endpoints (default: 300)
RATE_LIMIT_API=300
# Requests per minute per IP for AI generation endpoints (default: 20)
RATE_LIMIT_AI=20
# Requests per minute per IP for JIRA push endpoints (default: 60)
RATE_LIMIT_JIRA=60
