# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# ── Logging ───────────────────────────────────────────────────────────────────
# One of: debug | info | warn | error  (default: info)
LOG_LEVEL=info

# ── Audit log ─────────────────────────────────────────────────────────────────
# Path to the append-only NDJSON audit log. Set to "none" to disable auditing.
# Default: ./audit.log
AUDIT_LOG_PATH=./audit.log

# ── JIRA connection ───────────────────────────────────────────────────────────
JIRA_BASE_URL=https://your-jira-instance.example.com/jira
JIRA_API_TOKEN=your-personal-access-token

# ── JIRA project scoping ─────────────────────────────────────────────────────
# The JIRA project key used for all issue operations (default: EAMDM)
JIRA_PROJECT=EAMDM
# The JIRA label applied to issues created from this backlog (default: MIDAS_Development)
JIRA_LABEL=MIDAS_Development

# ── JIRA custom field IDs ─────────────────────────────────────────────────────
# These IDs are instance-specific. Find yours at:
#   JIRA > Administration > Issues > Custom fields
# (defaults below are for the VW Group JIRA instance)
JIRA_FIELD_EPIC_NAME=customfield_10002
JIRA_FIELD_EPIC_LINK=customfield_10000
JIRA_FIELD_STORY_POINTS=customfield_10006

# ── SSE connections ───────────────────────────────────────────────────────────
# Idle timeout in milliseconds before a silent SSE client is evicted (default: 300000 = 5 min)
SSE_IDLE_TIMEOUT_MS=300000

# ── AI generation ─────────────────────────────────────────────────────────────
# Max parallel AI (Claude / GitHub Models) calls at any given time (default: 3)
# Requests beyond this limit are queued in FIFO order rather than failing.
CLAUDE_CONCURRENCY=3

# ── JIRA performance ──────────────────────────────────────────────────────────
# Max parallel JIRA API requests during bulk operations (default: 5)
JIRA_CONCURRENCY=5
# Request timeout in milliseconds for JIRA API calls (default: 30000)
JIRA_TIMEOUT_MS=30000
